# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtualenv
.venv/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# IDE / OS
.idea/
.vscode/
.DS_Store
*~lock~

# AI assistant local settings
.claude/

# LaTeX build artifacts
*.aux
*.log
*.synctex.gz

# Screen recordings (demo GIF *source* — re-recorded and large; never commit the
# raw video. The final optimized GIF, if committed, lives under docs/images/.
# Keep working recordings in a local media/ scratch dir or attach to a Release.)
media/
*.mp4
*.mkv
*.mov

# Core dumps (a crashing test under the offscreen Qt platform can drop an 800 MB
# `core` in the repo root).
core
core.*

# Local scratch / generated artifacts
scratch_canvas.py
component_gallery.png
*.deb
# Hi-DPI .dmg background is rebuilt from the committed PNGs by scripts/make_dmg.py
assets/dmg-background.tiff
*.dmg

# Generated example outputs (regenerated by the app from the .hv source)
examples/**/*.pdf
examples/**/*.eps

# Signing keys — NEVER commit. These live in the macOS Keychain and GitHub
# Actions secrets only (base64-encoded). See .github/workflows/release.yml.
*.p12
*.p8
*.cer
*.mobileprovision
*.provisionprofile
